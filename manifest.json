{
  "manifest_version": 3,
  "name": "Boogily Boogily",
  "version": "1.0.0",
  "description": "Offline quick-copy text board.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "content-script.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "action": {
    "default_title": "Boogily Boogily",
    "default_popup": "popup.html"
  }
}
